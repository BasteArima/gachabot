# Telegram Bot Token (get it from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot Token
DISCORD_TOKEN=your_discord_token_here

# Discord OAuth / Activity (web login & embedded app — not the bot gateway).
# Needed only for Discord web/Activity login (HTTP slice C). Leave blank otherwise.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT=https://your-domain/api/auth/discord/callback

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=gachabot
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Settings
REQUIRE_18_PLUS_CONFIRM=true

COOLDOWN_HOURS=3

# Allow players to receive cards they already own. Set to false for a
# "collect them all, no duplicates" mode (disables crafting & duplicate counters).
ENABLE_DUPLICATES=true

ADMIN_TELEGRAM_ID=your_admin_telegram_id
ADMIN_TG_SUGGESTS_GROUP_ID=your_group_id
ADD_BOT_TO_GROUP_LINK=https://t.me/YOUR_BOT_bot?startgroup=true

START_BANNER_URL=https://site/banner.webp

ADMIN_TG_BACKUP_GROUP_ID=your_group_id
# Example: Every 03:10
BACKUP_TIME_HOUR=3
BACKUP_TIME_MINUTE=10

# Web/API layer (TMA, Discord Activity, browser). The Go service serves /api/*
# and (optionally) the built SPA from HTTP_STATIC_DIR. Put it behind your HTTPS
# reverse proxy (Mini App requires HTTPS).
HTTP_PORT=8080
# Directory with the built frontend (dist). In Docker this is baked into the
# image (/root/web) by the Dockerfile — set it only for local non-Docker runs.
HTTP_STATIC_DIR=
# Public HTTPS URL of the web app (used for buttons/redirects later).
WEB_APP_URL=https://your-domain
# Local dev only: treat unauthenticated requests as the admin user. NEVER in prod.
DEV_ALLOW_NO_AUTH=false

# Frontend build-time vars (baked into the SPA when the image is built).
# Bot username (no @) for the browser Telegram Login Widget; Discord app client id.
VITE_TG_BOT_USERNAME=
VITE_DISCORD_CLIENT_ID=